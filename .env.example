# Credenciais Infnet (e-mail + senha da plataforma)
FACULDADE_USER=
FACULDADE_PASS=

# URL da página de reuniões/transcrições (default pode ser sobrescrito)
CLASSES_URL=https://infnet.online/grupos/fundamentos-do-processamento-de-dados-26e1-26e2-93422564/infnet-ci-zoom-mettings/

# Nome da disciplina nos logs e no front-matter (opcional; senão tenta ler da página / URL)
# DISCIPLINE_NAME=Fundamentos de Python para processamento de dados

# Opcional: Chrome/Chromium já instalado (necessário se npm install foi com PUPPETEER_SKIP_DOWNLOAD=true)
# Windows exemplo: PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# HEADLESS=0 mostra o browser; ou na CLI: node stripper.js --headed (ou --show)
# PUPPETEER_EXECUTABLE_PATH=

# --- documentsScraper.js (BuddyPress Documentos) ---
